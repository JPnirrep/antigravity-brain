# .env.template

# Environment Variables for Gemini, Mercuri2, OpenRouter, Firebase, Telegram, and routing configuration

# Gemini Configuration
GEMINI_API_KEY='your_gemini_api_key_here'    # API key for Gemini service
GEMINI_API_SECRET='your_gemini_api_secret_here'  # Secret for Gemini API

# Mercuri2 Configuration
MERCURI2_API_URL='https://api.mercuri2.com'    # Base URL for Mercuri2 API
MERCURI2_API_KEY='your_mercuri2_api_key_here'   # API key for Mercuri2 service

# OpenRouter Configuration
OPENROUTER_API_URL='https://api.openrouter.com'  # Base URL for OpenRouter API
OPENROUTER_API_KEY='your_openrouter_api_key_here' # API key for OpenRouter service

# Firebase Configuration
FIREBASE_PROJECT_ID='your_firebase_project_id'          # Firebase Project ID
FIREBASE_API_KEY='your_firebase_api_key_here'          # API key for Firebase
FIREBASE_AUTH_DOMAIN='your_firebase_auth_domain_here'  # Firebase Auth domain

# Telegram Configuration
TELEGRAM_BOT_TOKEN='your_telegram_bot_token_here'  # Token for Telegram bot
TELEGRAM_CHAT_ID='your_telegram_chat_id_here'      # Chat ID for sending messages

# Routing Configuration
ROUTING_HOST='localhost'          # Host for routing service
ROUTING_PORT='3000'               # Port for routing service
ROUTING_API_KEY='your_routing_api_key_here'   # API key for the routing service

# You can add additional required environment variables here as needed.
