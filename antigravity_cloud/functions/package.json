{
    "name": "antigravity-cloud",
    "description": "Cerveau Cloud Antigravity sur Firebase Functions",
    "main": "lib/index.js",
    "scripts": {
        "lint": "eslint \"src/**/*\"",
        "build": "tsc",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log"
    },
    "engines": {
        "node": "20"
    },
    "dependencies": {
        "axios": "^1.6.0",
        "dotenv": "^16.3.1",
        "firebase-admin": "^13.7.0",
        "firebase-functions": "^7.0.6"
    },
    "devDependencies": {
        "@types/dotenv": "^6.1.1",
        "@types/node": "^25.3.3",
        "firebase-functions-test": "^3.1.0",
        "ts-node": "^10.9.2",
        "typescript": "^4.9.5"
    },
    "private": true
}
